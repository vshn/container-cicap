{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "reviewers": ["team:nunki"],
  "pinDigests": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/.*Containerfile/"],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)?\\s.*ENV .*_VERSION=\"?(?<currentValue>.*)\"?\\s"
      ]
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true
    },
    {
      "matchDatasources": ["github-tags"],
      "extractVersion": "^v?(?<version>.*)$"
    },
    {
      "matchDepNames": ["c-icap/c-icap-server"],
      "extractVersion": "^C_ICAP_?(?<version>.*)$"
    }
  ]
}
